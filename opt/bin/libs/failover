. /opt/apps/kvas/bin/libs/main
. /opt/apps/kvas/bin/libs/vpn

# –Ъ–Њ–љ—Д–Є–≥—Г—А–∞—Ж–Є—П failover
FAILOVER_CONF="/opt/etc/kvas.failover.conf"
FAILOVER_LOG="/opt/var/log/kvas-failover.log"

# –Ш–љ–Є—Ж–Є–∞–ї–Є–Ј–∞—Ж–Є—П –Ї–Њ–љ—Д–Є–≥–∞ failover
init_failover_conf() {
    if [ ! -f "$FAILOVER_CONF" ]; then
        cat > "$FAILOVER_CONF" << 'EOF'
FAILOVER_MODE=failover
VLESS_PRIORITY=1
HYSTERIA_PRIORITY=2
CHECK_INTERVAL=15
FAIL_THRESHOLD=2
AUTO_START=yes
EOF
    fi
}

load_failover_conf() {
    init_failover_conf
    . "$FAILOVER_CONF"
}

save_failover_conf() {
    init_failover_conf
    cat > "$FAILOVER_CONF" << EOF
FAILOVER_MODE=${FAILOVER_MODE:-failover}
VLESS_PRIORITY=${VLESS_PRIORITY:-1}
HYSTERIA_PRIORITY=${HYSTERIA_PRIORITY:-2}
CHECK_INTERVAL=${CHECK_INTERVAL:-15}
FAIL_THRESHOLD=${FAIL_THRESHOLD:-2}
AUTO_START=${AUTO_START:-yes}
EOF
}

# –Я—А–Њ–≤–µ—А–Ї–∞ —А–∞–±–Њ—В–Њ—Б–њ–Њ—Б–Њ–±–љ–Њ—Б—В–Є vless
check_vless() {
    local pidfile="/var/run/xray.pid"
    local was_running=0
    
    if [ -f "$pidfile" ] && kill -0 $(cat "$pidfile" 2>/dev/null) 2>/dev/null; then
        was_running=1
    fi
    
    if [ "$was_running" -eq 0 ]; then
        /opt/etc/init.d/S97xray start 2>/dev/null
        sleep 2
    fi
    
    local ip=$(curl -s --connect-timeout 5 -x "socks5://127.0.0.1:1097" "https://ifconfig.me" 2>/dev/null)
    local result=1
    if [ -n "$ip" ] && echo "$ip" | grep -qE "^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$"; then
        result=0
    fi
    
    if [ "$was_running" -eq 0 ]; then
        /opt/etc/init.d/S97xray stop 2>/dev/null
    fi
    
    return $result
}

# –Я—А–Њ–≤–µ—А–Ї–∞ —А–∞–±–Њ—В–Њ—Б–њ–Њ—Б–Њ–±–љ–Њ—Б—В–Є hysteria
check_hysteria() {
    local pidfile="/var/run/hysteria.pid"
    local bin_path="/opt/apps/kvas/hysteria/bin/hysteria"
    
    if [ ! -f "$pidfile" ] || ! kill -0 $(cat "$pidfile" 2>/dev/null) 2>/dev/null; then
        return 1
    fi
    
    local ip=$(curl -s --connect-timeout 5 -x "socks5://127.0.0.1:10808" "https://ifconfig.me" 2>/dev/null)
    if [ -n "$ip" ] && echo "$ip" | grep -qE "^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$"; then
        return 0
    fi
    
    return 1
}

get_active_protocol() {
    if check_vless; then
        echo "vless"
    elif check_hysteria; then
        echo "hysteria"
    else
        echo "none"
    fi
}

# –Я–µ—А–µ–Ї–ї—О—З–µ–љ–Є–µ –љ–∞ vless - –Є—Б–њ–Њ–ї—М–Ј—Г–µ–Љ switch_vpn_on –Є–Ј vpn –±–Є–±–ї–Є–Њ—В–µ–Ї–Є
switch_to_vless() {
    log_failover "–Я–µ—А–µ–Ї–ї—О—З–µ–љ–Є–µ –љ–∞ VLESS..."
    
    # –Ш—Б–њ–Њ–ї—М–Ј—Г–µ–Љ switch_vpn_on - —В—Г –ґ–µ —Д—Г–љ–Ї—Ж–Є—О —З—В–Њ –Є kvas vpn set
    # Proxy21 - —Н—В–Њ entware –Є–Љ—П –і–ї—П vless –Є–љ—В–µ—А—Д–µ–є—Б–∞
    switch_vpn_on "Proxy21" "Proxy21" 2>/dev/null
    
    log_failover "–Я–µ—А–µ–Ї–ї—О—З–µ–љ–Њ –љ–∞ VLESS"
    return 0
}

# –Я–µ—А–µ–Ї–ї—О—З–µ–љ–Є–µ –љ–∞ hysteria - –Є—Б–њ–Њ–ї—М–Ј—Г–µ–Љ switch_vpn_on –Є–Ј vpn –±–Є–±–ї–Є–Њ—В–µ–Ї–Є
switch_to_hysteria() {
    log_failover "–Я–µ—А–µ–Ї–ї—О—З–µ–љ–Є–µ –љ–∞ Hysteria..."
    
    # –Ш—Б–њ–Њ–ї—М–Ј—Г–µ–Љ switch_vpn_on - —В—Г –ґ–µ —Д—Г–љ–Ї—Ж–Є—О —З—В–Њ –Є kvas vpn set
    # Proxy41 - —Н—В–Њ entware –Є–Љ—П –і–ї—П hysteria –Є–љ—В–µ—А—Д–µ–є—Б–∞
    switch_vpn_on "Proxy41" "Proxy41" 2>/dev/null
    
    log_failover "–Я–µ—А–µ–Ї–ї—О—З–µ–љ–Њ –љ–∞ Hysteria"
    return 0
}

log_failover() {
    local msg="$1"
    local timestamp=$(date '+%Y-%m-%d %H:%M:%S')
    mkdir -p /opt/var/log
    echo "[$timestamp] $msg" >> "$FAILOVER_LOG"
    if [ -f "$FAILOVER_LOG" ]; then
        tail -100 "$FAILOVER_LOG" > "${FAILOVER_LOG}.tmp"
        mv "${FAILOVER_LOG}.tmp" "$FAILOVER_LOG"
    fi
}

FAIL_COUNT=0

run_failover_check() {
    load_failover_conf
    
    if [ "$FAILOVER_MODE" != "failover" ]; then
        return 0
    fi
    
    local active=$(get_active_protocol)
    local vless_ok=0
    local hysteria_ok=0
    
    check_vless && vless_ok=1
    check_hysteria && hysteria_ok=1
    
    local primary=""
    local secondary=""
    
    if [ "$VLESS_PRIORITY" -lt "$HYSTERIA_PRIORITY" ]; then
        primary="vless"
        secondary="hysteria"
    else
        primary="hysteria"
        secondary="vless"
    fi
    
    log_failover "–Я—А–Њ–≤–µ—А–Ї–∞: vless=$vless_ok hysteria=$hysteria_ok active=$active primary=$primary"
    
    if [ "$active" = "$primary" ]; then
        FAIL_COUNT=0
        return 0
    elif [ "$active" = "none" ] || [ "$active" != "$primary" ]; then
        FAIL_COUNT=$((FAIL_COUNT + 1))
        
        if [ "$FAIL_COUNT" -ge "$FAIL_THRESHOLD" ]; then
            log_failover "–Я—А–µ–≤—Л—И–µ–љ –њ–Њ—А–Њ–≥ –Њ—И–Є–±–Њ–Ї ($FAIL_COUNT). –Я–µ—А–µ–Ї–ї—О—З–µ–љ–Є–µ..."
            
            if [ "$primary" = "vless" ] && [ "$vless_ok" -eq 1 ]; then
                switch_to_vless
            elif [ "$primary" = "hysteria" ] && [ "$hysteria_ok" -eq 1 ]; then
                switch_to_hysteria
            elif [ "$secondary" = "vless" ] && [ "$vless_ok" -eq 1 ]; then
                switch_to_vless
            elif [ "$secondary" = "hysteria" ] && [ "$hysteria_ok" -eq 1 ]; then
                switch_to_hysteria
            fi
            
            FAIL_COUNT=0
        fi
    fi
}

start_failover_daemon() {
    load_failover_conf
    sleep 60
    while true; do
        run_failover_check >> /dev/null 2>&1
        sleep "$CHECK_INTERVAL"
    done
}

stop_failover_daemon() {
    local pidfile="/var/run/kvas-failover.pid"
    if [ -f "$pidfile" ]; then
        kill $(cat "$pidfile" 2>/dev/null) 2>/dev/null
        rm -f "$pidfile"
        echo "–Ф–µ–Љ–Њ–љ failover –Њ—Б—В–∞–љ–Њ–≤–ї–µ–љ"
    fi
}

show_failover_status() {
    load_failover_conf
    
    echo "=== –°—В–∞—В—Г—Б –∞–≤—В–Њ–њ–µ—А–µ–Ї–ї—О—З–µ–љ–Є—П ==="
    echo "–†–µ–ґ–Є–Љ: $FAILOVER_MODE"
    echo "–Я—А–Є–Њ—А–Є—В–µ—В VLESS: $VLESS_PRIORITY"
    echo "–Я—А–Є–Њ—А–Є—В–µ—В Hysteria: $HYSTERIA_PRIORITY"
    echo "–Ш–љ—В–µ—А–≤–∞–ї –њ—А–Њ–≤–µ—А–Ї–Є: $CHECK_INTERVAL —Б–µ–Ї"
    echo "–Я–Њ—А–Њ–≥ –Њ—И–Є–±–Њ–Ї: $FAIL_THRESHOLD"
    echo ""
    
    echo "–Ґ–µ–Ї—Г—Й–Є–є —Б—В–∞—В—Г—Б:"
    local active=$(get_active_protocol)
    
    if check_vless; then
        echo -e "  VLESS:    ${GREEN}–†–∞–±–Њ—В–∞–µ—В${NC}"
    else
        echo -e "  VLESS:    ${RED}–Э–µ —А–∞–±–Њ—В–∞–µ—В${NC}"
    fi
    
    if check_hysteria; then
        echo -e "  Hysteria: ${GREEN}–†–∞–±–Њ—В–∞–µ—В${NC}"
    else
        echo -e "  Hysteria: ${RED}–Э–µ —А–∞–±–Њ—В–∞–µ—В${NC}"
    fi
    
    echo ""
    echo "–Р–Ї—В–Є–≤–љ—Л–є –њ—А–Њ—В–Њ–Ї–Њ–ї: ${BLUE}${active}${NC}"
    
    local pidfile="/var/run/kvas-failover.pid"
    if [ -f "$pidfile" ] && kill -0 $(cat "$pidfile" 2>/dev/null) 2>/dev/null; then
        echo -e "–Ф–µ–Љ–Њ–љ: ${GREEN}–Ч–∞–њ—Г—Й–µ–љ${NC} (PID: $(cat "$pidfile"))"
    else
        echo -e "–Ф–µ–Љ–Њ–љ: ${RED}–Ю—Б—В–∞–љ–Њ–≤–ї–µ–љ${NC}"
    fi
    
    if [ -f "$FAILOVER_LOG" ]; then
        echo ""
        echo "–Я–Њ—Б–ї–µ–і–љ–Є–µ —Б–Њ–±—Л—В–Є—П:"
        tail -5 "$FAILOVER_LOG" | sed 's/^/  /'
    fi
}

cmd_failover() {
    case "${1}" in
        on)
            load_failover_conf
            FAILOVER_MODE=failover
            save_failover_conf
            echo "–Р–≤—В–Њ–њ–µ—А–µ–Ї–ї—О—З–µ–љ–Є–µ –≤–Ї–ї—О—З–µ–љ–Њ"
            mkdir -p /opt/var/log
            local pidfile="/var/run/kvas-failover.pid"
            if [ -f "$pidfile" ] && kill -0 $(cat "$pidfile" 2>/dev/null) 2>/dev/null; then
                echo "–Ф–µ–Љ–Њ–љ —Г–ґ–µ –Ј–∞–њ—Г—Й–µ–љ"
            else
                start_failover_daemon &
                echo $! > "$pidfile"
                echo "–Ф–µ–Љ–Њ–љ –Ј–∞–њ—Г—Й–µ–љ (PID: $!)"
            fi
            ;;
        off)
            load_failover_conf
            FAILOVER_MODE=manual
            save_failover_conf
            stop_failover_daemon
            echo "–Р–≤—В–Њ–њ–µ—А–µ–Ї–ї—О—З–µ–љ–Є–µ –Њ—В–Ї–ї—О—З–µ–љ–Њ"
            ;;
        vless-only)
            load_failover_conf
            FAILOVER_MODE=vless-only
            save_failover_conf
            echo "–†–µ–ґ–Є–Љ: —В–Њ–ї—М–Ї–Њ VLESS"
            ;;
        hysteria-only)
            load_failover_conf
            FAILOVER_MODE=hysteria-only
            save_failover_conf
            echo "–†–µ–ґ–Є–Љ: —В–Њ–ї—М–Ї–Њ Hysteria"
            ;;
        start)
            local pidfile="/var/run/kvas-failover.pid"
            if [ -f "$pidfile" ] && kill -0 $(cat "$pidfile" 2>/dev/null) 2>/dev/null; then
                echo "–Ф–µ–Љ–Њ–љ —Г–ґ–µ –Ј–∞–њ—Г—Й–µ–љ"
            else
                start_failover_daemon &
                echo $! > "$pidfile"
                echo "–Ф–µ–Љ–Њ–љ –Ј–∞–њ—Г—Й–µ–љ"
            fi
            ;;
        stop)
            stop_failover_daemon
            ;;
        status)
            show_failover_status
            ;;
        set)
            case "${2}" in
                vless-priority)
                    load_failover_conf
                    VLESS_PRIORITY="${3:-1}"
                    [ "$VLESS_PRIORITY" = "1" ] && HYSTERIA_PRIORITY=2 || HYSTERIA_PRIORITY=1
                    save_failover_conf
                    echo "VLESS –њ—А–Є–Њ—А–Є—В–µ—В: $VLESS_PRIORITY"
                    ;;
                hysteria-priority)
                    load_failover_conf
                    HYSTERIA_PRIORITY="${3:-1}"
                    [ "$HYSTERIA_PRIORITY" = "1" ] && VLESS_PRIORITY=2 || VLESS_PRIORITY=1
                    save_failover_conf
                    echo "Hysteria –њ—А–Є–Њ—А–Є—В–µ—В: $HYSTERIA_PRIORITY"
                    ;;
                interval)
                    load_failover_conf
                    CHECK_INTERVAL="${3:-15}"
                    save_failover_conf
                    echo "–Ш–љ—В–µ—А–≤–∞–ї –њ—А–Њ–≤–µ—А–Ї–Є: $CHECK_INTERVAL —Б–µ–Ї"
                    ;;
                threshold)
                    load_failover_conf
                    FAIL_THRESHOLD="${3:-2}"
                    save_failover_conf
                    echo "–Я–Њ—А–Њ–≥ –Њ—И–Є–±–Њ–Ї: $FAIL_THRESHOLD"
                    ;;
                *)
                    echo "–Ш—Б–њ–Њ–ї—М–Ј–Њ–≤–∞–љ–Є–µ: kvas failover set {vless-priority|hysteria-priority|interval|threshold} [–Ј–љ–∞—З–µ–љ–Є–µ]"
                    ;;
            esac
            ;;
        log)
            if [ -f "$FAILOVER_LOG" ]; then
                tail -${2:-20} "$FAILOVER_LOG"
            else
                echo "–Ы–Њ–≥ –њ—Г—Б—В"
            fi
            ;;
        *)
            echo "–Ш—Б–њ–Њ–ї—М–Ј–Њ–≤–∞–љ–Є–µ: kvas failover {on|off|start|stop|status|set|log}"
            echo ""
            echo "–Ъ–Њ–Љ–∞–љ–і—Л:"
            echo "  on              - –≤–Ї–ї—О—З–Є—В—М –∞–≤—В–Њ–њ–µ—А–µ–Ї–ї—О—З–µ–љ–Є–µ"
            echo "  off             - –Њ—В–Ї–ї—О—З–Є—В—М –∞–≤—В–Њ–њ–µ—А–µ–Ї–ї—О—З–µ–љ–Є–µ"
            echo "  vless-only      - —В–Њ–ї—М–Ї–Њ VLESS"
            echo "  hysteria-only   - —В–Њ–ї—М–Ї–Њ Hysteria"
            echo "  start           - –Ј–∞–њ—Г—Б—В–Є—В—М –і–µ–Љ–Њ–љ –Љ–Њ–љ–Є—В–Њ—А–Є–љ–≥–∞"
            echo "  stop            - –Њ—Б—В–∞–љ–Њ–≤–Є—В—М –і–µ–Љ–Њ–љ"
            echo "  status          - –њ–Њ–Ї–∞–Ј–∞—В—М —Б—В–∞—В—Г—Б"
            echo "  set <param> [val] - –љ–∞—Б—В—А–Њ–Є—В—М –њ–∞—А–∞–Љ–µ—В—А—Л"
            echo "  log [N]         - –њ–Њ–Ї–∞–Ј–∞—В—М –њ–Њ—Б–ї–µ–і–љ–Є–µ N –Ј–∞–њ–Є—Б–µ–є –ї–Њ–≥–∞"
            ;;
    esac
}