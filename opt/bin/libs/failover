#!/bin/sh
# ------------------------------------------------------------------------------------------
#
# 	–Я–†–Ю–Х–Ъ–Ґ –Ъ–Т–Р–°
#
# 	–Ь–Њ–і—Г–ї—М –∞–≤—В–Њ–њ–µ—А–µ–Ї–ї—О—З–µ–љ–Є—П –Љ–µ–ґ–і—Г vless –Є hysteria
# ------------------------------------------------------------------------------------------
